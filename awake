# --- Commands ---

write_runtime_agent() {
    local command_path
    command_path="$(runtime_command_path)"
    mkdir -p "$(dirname "$RUNTIME_PATH")"
    cat > "$RUNTIME_PATH" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>$RUNTIME_LABEL</string>
    <key>ProgramArguments</key>
    <array>
        <string>$command_path</string>
        <string>_runtime</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>2</integer>
    <key>ProcessType</key>
    <string>Background</string>
    <key>StandardOutPath</key>
    <string>/tmp/awake.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/awake.log</string>
</dict>
</plist>
EOF
}

remove_legacy_jobs() {
    local label path
    for label in "$LEGACY_DAEMON_LABEL" "$LEGACY_MONITOR_LABEL"; do
        "$LAUNCHCTL_BIN" bootout "$(legacy_target "$label")" >/dev/null 2>&1 || true
    done
    for path in "$LEGACY_DAEMON_PATH" "$LEGACY_MONITOR_PATH"; do
        rm -f "$path"
    done
}

install_runtime() {
    local attempt=0 previous_pid=""
    if [ -f "$LEGACY_DAEMON_PATH" ] || "$LAUNCHCTL_BIN" print "$(legacy_target "$LEGACY_DAEMON_LABEL")" >/dev/null 2>&1; then
        mkdir -p "$(dirname "$AGENT_AUTO_FILE")"
        touch "$AGENT_AUTO_FILE"
    fi
    remove_legacy_jobs
    previous_pid="$(active_runtime_pid 2>/dev/null || true)"
    if runtime_loaded; then
        "$LAUNCHCTL_BIN" bootout "$(runtime_target)" >/dev/null 2>&1 || {
            log "ERROR: launchd could not reload $RUNTIME_LABEL"
            return 1
        }
    fi
    if [ -n "$previous_pid" ]; then
        while pid_matches_awake_runtime "$previous_pid" && [ "$attempt" -lt 50 ]; do
            sleep 0.05
            attempt=$(( attempt + 1 ))
        done
        if pid_matches_awake_runtime "$previous_pid"; then
            log "ERROR: previous Awake runtime did not stop during upgrade"
            return 1
        fi
    fi
    attempt=0
    if [ -d "$DAEMON_LOCK_DIR" ]; then
        local lock_owner
        lock_owner="$(read_file_value "$DAEMON_OWNER_FILE" 2>/dev/null || true)"
        pid_matches_awake_runtime "$lock_owner" || rm -rf "$DAEMON_LOCK_DIR"
    fi
    rm -f "$PID_FILE" "$RUNTIME_READY_FILE" "$RUNTIME_HEARTBEAT_FILE"
    write_runtime_agent || return 1
    "$LAUNCHCTL_BIN" bootstrap "$(launch_agent_domain)" "$RUNTIME_PATH" >/dev/null 2>&1 || {
        log "ERROR: launchd could not load $RUNTIME_LABEL"
        return 1
    }
    "$LAUNCHCTL_BIN" kickstart "$(runtime_target)" >/dev/null 2>&1 || {
        log "ERROR: launchd could not start $RUNTIME_LABEL"
        return 1
    }
    while [ "$attempt" -lt 50 ]; do
        if runtime_is_healthy; then
            log "Runtime ready (PID $(runtime_ready_pid))"
            return 0
        fi
        sleep 0.05
        attempt=$(( attempt + 1 ))
    done
    log "ERROR: Awake runtime did not become healthy"
    return 1
}

ensure_runtime_ready() {
    runtime_is_healthy && return 0
    log "ERROR: Awake runtime is not running. Repair it with: awake install"
    return 1
}

cmd_runtime_status() {
    if runtime_is_healthy; then
        printf 'ready\n'
        return 0
    fi
    printf 'unavailable\n'
    return 1
}

runtime_write_heartbeat() {
    printf '%s\n' "$(now_epoch)" > "$RUNTIME_HEARTBEAT_FILE"
}

runtime_reconcile_once() {
    cleanup_invalid_leases
    sync_rule_leases

    if ! agent_auto_enabled; then
        lease_remove "daemon-agent"
        RUNTIME_GRACE_START=0
    elif timer_running; then
        RUNTIME_GRACE_START=0
    elif agents_running; then
        echo "$(now_epoch)" > "$LAST_ACTIVE_FILE"
        RUNTIME_GRACE_START=0
        lease_create_or_update "daemon-agent" "daemon" "$(current_default_mode)" "Detected active coding agents" 70 "" "runtime"
    else
        lease_remove "daemon-agent"
        if [ "$(rule_lease_count)" -gt 0 ]; then
            RUNTIME_GRACE_START=0
        elif [ "$RUNTIME_GRACE_START" -eq 0 ]; then
            RUNTIME_GRACE_START="$(now_epoch)"
            log "No agents — grace period ($(( GRACE_SECONDS / 60 ))m)"
        else
            local remaining=$(( GRACE_SECONDS - ($(now_epoch) - RUNTIME_GRACE_START) ))
            if [ "$remaining" -le 0 ]; then
                log "Grace expired — restoring normal sleep"
                notify "Awake" "No coding agents are active. Normal sleep restored."
                force_sleep_if_unleased
                RUNTIME_GRACE_START=0
            fi
        fi
    fi

    if ! reconcile_effective_state; then
        log "ERROR: runtime reconciliation failed; restoring normal sleep"
        restore_sleep_after_runtime_failure
        RUNTIME_GRACE_START=0
        return 1
    fi
}

cmd_runtime() {
    trap runtime_cleanup EXIT
    trap runtime_signal_exit INT TERM
    ensure_runtime_dirs
    if ! acquire_runtime_lock; then
        log "Another Awake runtime is already running"
        return 1
    fi
    printf '%s\n' "$$" > "$PID_FILE"
    log "Runtime started (PID $$, poll=${POLL_INTERVAL}s, grace=${GRACE_SECONDS}s)"
    log "Watching: $AGENTS"
    if ! acquire_reconcile_lock; then
        log "ERROR: runtime could not acquire startup reconciliation"
        return 1
    fi
    local recovery_status=0
    recover_power_state_on_launch || recovery_status=$?
    release_reconcile_lock
    if [ "$recovery_status" -ne 0 ]; then
        log "ERROR: runtime startup recovery failed"
        return "$recovery_status"
    fi
    printf '%s\n' "$$" > "$RUNTIME_READY_FILE"
    runtime_write_heartbeat
    RUNTIME_GRACE_START=0
    runtime_reconcile_once || true
    while true; do
        runtime_wait
        runtime_write_heartbeat
        runtime_reconcile_once || true
    done
}

cmd_agent_auto() {
    local action="${1:-status}"
    case "$action" in
        on|enable|enabled)
            ensure_runtime_ready || return 1
            mkdir -p "$(dirname "$AGENT_AUTO_FILE")"
            touch "$AGENT_AUTO_FILE"
            if agents_running; then
                lease_create_or_update "daemon-agent" "daemon" "$(current_default_mode)" "Detected active coding agents" 70 "" "runtime"
                reconcile_effective_state || return 1
            fi
            log "Automatic agent protection enabled"
            ;;
        off|disable|disabled)
            rm -f "$AGENT_AUTO_FILE"
            lease_remove "daemon-agent"
            reconcile_effective_state || return 1
            log "Automatic agent protection disabled"
            ;;
        status)
            agent_auto_enabled && echo "enabled" || echo "disabled"
            ;;
        *)
            echo "Usage: awake agent-auto [on|off|status]"
            return 1
            ;;
    esac
}

cmd_daemon_start() {
    cmd_agent_auto on
}

cmd_stop() {
    rm -f "$AGENT_AUTO_FILE"
    cancel_timer_session
    lease_remove "manual-toggle"
    lease_remove "daemon-agent"
    local dir
    for dir in "$LEASES_DIR"/rule-*; do
        [ -d "$dir" ] || continue
        rm -rf "$dir"
    done
    reconcile_effective_state
    rm -f "$LAST_ACTIVE_FILE"
    log "Awake sessions stopped; the safety runtime remains supervised by launchd"
}

cmd_status() {
    if [ "${1:-}" = "--json" ]; then
        refresh_setup_flags
        setup_status_json
        return 0
    fi
    local runtime_pid=""
    runtime_pid="$(active_runtime_pid 2>/dev/null || true)"

    local state=$(current_state)
    local agents=$(agent_summary)

    echo "runtime:      $([ -n "$runtime_pid" ] && echo "running (PID $runtime_pid)" || echo "unavailable — run awake install")"
    echo "agent auto:   $(agent_auto_enabled && echo enabled || echo disabled)"
    echo "power state:  $state"
    echo "mode:         $(effective_mode_value 2>/dev/null || echo "normal")"
    echo "agents:       $agents"
    echo "watching:     $AGENTS"
    echo "why:          $(why_summary)"

    if [ -f "$LAST_ACTIVE_FILE" ]; then
        local last=$(cat "$LAST_ACTIVE_FILE")
        local ago=$(( $(now_epoch) - last ))
        if [ "$ago" -lt 60 ]; then
            echo "last active:  ${ago}s ago"
        else
            echo "last active:  $(( ago / 60 ))m ago"
        fi
    fi

    # Battery
    local batt=$(get_battery_pct)
    if [ -n "$batt" ]; then
        local charge_state="discharging"
        is_charging && charge_state="charging"
        echo "battery:      ${batt}% ($charge_state)"
    else
        echo "battery:      N/A (no battery or desktop Mac)"
    fi

    # For timer
    if timer_running; then
        echo "for timer:    active"
    fi
    echo "leases:       $(lease_count)"
    echo "rules:        $(rule_count)"

    # Sudoers
    if sudo -n pmset -g >/dev/null 2>&1; then
        echo "sudo pmset:   OK"
    else
        echo "sudo pmset:   NOT CONFIGURED"
    fi
    if sudo -n powermetrics -h >/dev/null 2>&1; then
        echo "sudo temp:    OK"
    else
        echo "sudo temp:    NOT CONFIGURED"
    fi
}

cmd_why() {
    if [ "${1:-}" = "--json" ]; then
        refresh_setup_flags
        setup_status_json
        return 0

    app_version="$(current_app_version)"
    force_refresh="${1:-false}"
    python_update_tool update-status \
        "$UPDATE_CACHE_FILE" \
        "$PACKAGE_NAME" \
        "$current_version" \
        "$app_version" \
        "$source_type" \
